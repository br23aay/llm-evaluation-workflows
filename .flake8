[flake8]
# report.py embeds long HTML/CSS template strings for the HTML report
# output — wrapping these would hurt readability more than it helps, so
# line length is relaxed rather than artificially wrapping markup.
max-line-length = 160

# E731 (lambda assignment) is used once in report.py as a small sort-key
# helper; a full def would be more verbose for no real benefit here.
#
# E221 (multiple spaces before operator) shows up in report.py's CSS
# variable block, where values are intentionally column-aligned for
# readability.
#
# E231 (missing whitespace after comma) and E127 (over-indented
# continuation line) show up in evaluator.py's regex pattern tables,
# where entries are deliberately aligned in columns rather than
# reflowed one-per-line.
#
# F541 (f-string missing placeholders) is used a few times for strings
# that are f-strings for consistency with neighbouring lines that do
# interpolate; not worth splitting into two string styles.
extend-ignore = E731,E221,E231,E127,F541

# Test files intentionally do sys.path manipulation before importing the
# package under test (this repo has no setup.py / packaging), so the
# import-not-at-top-of-file rule is expected and not a real issue.
# run_evaluation.py does the same for its own CLI entry point imports.
per-file-ignores =
    tests/*.py:E402
    run_evaluation.py:E402
